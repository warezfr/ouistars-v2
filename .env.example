# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Notifications e-mail
OPS_NOTIFY_EMAIL=ops@ouistars.com
# Adresse d'expéditeur (SMTP et Resend). Doit être une boîte que vous possédez.
MAIL_FROM=Oui Stars <bookings@ouistars.com>

# --- Canal 1 : SMTP (nodemailer). Serveur mail classique (Zoho, GoDaddy…).
# ⚠ GoDaddy Node.js Hosting bloque les ports sortants sauf 80/443 : un SMTP sur
#   465/587/25 y sera bloqué. Testez avec /api/email/test avant de compter dessus.
# Ex. Zoho EU : SMTP_HOST=smtp.zoho.eu  SMTP_PORT=465  SMTP_SECURE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Clé pour activer le diagnostic POST /api/email/test (laisser vide = désactivé)
EMAIL_TEST_KEY=

# --- Canal 1bis : Zoho ZeptoMail (API HTTPS — recommandé, cohérent avec vos boîtes Zoho).
# Créez un compte sur zeptomail.zoho.eu, vérifiez le domaine ouistars.com,
# puis copiez le « Send Mail token » de votre Mail Agent.
ZEPTO_API_KEY=
ZEPTO_HOST=api.zeptomail.eu

# --- Canal 2 : Resend (API HTTPS). Fonctionne malgré la restriction de ports.
RESEND_API_KEY=

# Company
VITE_WHATSAPP_NUMBER=33651030306
VITE_CONTACT_EMAIL=info@ouistars.com

# API fournisseur ETG (Basic Auth — identifiants communiqués à ETG)
ETG_BASIC_AUTH_USER=
ETG_BASIC_AUTH_PASS=
# Optionnel : jeton Bearer statique de repli + limite de débit (req/min/IP)
ETG_BEARER_TOKEN=
ETG_RATE_LIMIT=120
# Optionnel : routage réel (sinon repli OSRM public puis haversine)
GOOGLE_MAPS_API_KEY=
OSRM_BASE_URL=
# URL publique pour les liens fournisseur dans les réponses /book
PUBLIC_SITE_URL=https://ouistars-v2.vercel.app
