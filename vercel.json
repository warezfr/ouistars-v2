{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "rewrites": [
    { "source": "/search", "destination": "/api/search" },
    { "source": "/book", "destination": "/api/book" },
    { "source": "/status", "destination": "/api/status" },
    { "source": "/cancel", "destination": "/api/cancel" },
    { "source": "/((?!api/|search$|book$|status$|cancel$|openapi\\.yaml$).*)", "destination": "/index.html" }
  ]
}
